# Database
DATABASE_URL=postgresql://dp_user:dp_pass@localhost:5432/data_platform
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# API authentication key (required, change in production)
API_KEY=change-me-in-production

# Fernet encryption key for connector credentials (required, change in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-in-production

# Celery (defaults to REDIS_URL if empty)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# CORS origins (comma-separated)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# Scheduler
SCHEDULER_SYNC_INTERVAL=15

# Sync task retry
SYNC_TASK_MAX_RETRIES=3
SYNC_TASK_RETRY_BACKOFF=60

# Distributed lock timeout (seconds)
SYNC_LOCK_TIMEOUT=3600
